{
  "name": "qunitx-cli",
  "type": "module",
  "version": "0.5.5",
  "description": "Browser runner for QUnitx: run your qunitx tests in google-chrome",
  "main": "cli.js",
  "author": "Izel Nakri",
  "license": "MIT",
  "keywords": [
    "test runner",
    "testing",
    "browser",
    "ci",
    "qunit",
    "qunitx"
  ],
  "scripts": {
    "bin": "chmod +x cli.js && ./cli.js",
    "format": "prettier --check \"lib/**/*.js\" \"test/**/*.js\" \"*.js\" \"package.json\" \".github/**/*.yml\"",
    "format:fix": "prettier --write \"lib/**/*.js\" \"test/**/*.js\" \"*.js\" \"package.json\" \".github/**/*.yml\"",
    "lint": "deno lint lib/ cli.js",
    "lint:docs": "deno doc --lint lib/commands/*.js",
    "docs": "deno doc --html --name=\"qunitx-cli\" --output=docs/lib 'lib/**/*.js'",
    "build": "node build.js",
    "changelog:unreleased": "git-cliff --unreleased --strip all",
    "changelog:preview": "git-cliff",
    "changelog:update": "git-cliff --output CHANGELOG.md",
    "postinstall": "deno install --allow-scripts=npm:puppeteer || true",
    "prepack": "npm run build",
    "test": "node test/setup.js && FORCE_COLOR=0 node --test test/**/*-test.js",
    "test:sanity-first": "./cli.js test/helpers/failing-tests.js test/helpers/failing-tests.ts",
    "test:sanity-second": "./cli.js test/helpers/passing-tests.js test/helpers/passing-tests.ts"
  },
  "engines": {
    "node": ">=24.0.0",
    "deno": ">=2.7.0"
  },
  "bin": {
    "qunitx": "cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/izelnakri/qunitx-cli.git"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "esbuild": "^0.27.3",
    "js-yaml": "^4.1.1",
    "kleur": "^4.1.5",
    "picomatch": "^4.0.3",
    "puppeteer": "^24.38.0",
    "recursive-lookup": "1.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "prettier": "^3.8.1",
    "qunit": "^2.25.0",
    "qunitx": "^1.0.0"
  },
  "volta": {
    "node": "24.14.0"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "arrowParens": "always"
  }
}
